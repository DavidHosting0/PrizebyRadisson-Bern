# API (apps/api)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/housekeeping
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_DAYS=7
PORT=3001
WEB_ORIGIN=http://localhost:3000

# S3-compatible (MinIO local: http://localhost:9000)
S3_REGION=us-east-1
S3_BUCKET=housekeeping
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio123

# Optional: auto-assign interval for background job (ms)
AUTO_ASSIGN_INTERVAL_MS=60000

# Web (apps/web)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
