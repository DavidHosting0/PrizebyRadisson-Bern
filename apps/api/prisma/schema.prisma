generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  HOUSEKEEPER
  SUPERVISOR
  RECEPTION
  ADMIN
  TECHNICIAN
}

/** Shown in chat, headers, and assignments (independent of permission role). */
enum UserTitlePrefix {
  CLEANER
  HOUSEKEEPING_SUPERVISOR
  RECEPTION
  HTC_IN_TRAINING
  HTC
  ADMIN
  TECHNICIAN
}

/** Fine-grained access; merged with role + titlePrefix defaults + per-user grants. */
enum PermissionCode {
  ROOMS_READ
  ROOMS_UPDATE
  CHECKLIST_TASK_UPDATE
  CHECKLIST_REOPEN
  PHOTO_UPLOAD
  PHOTO_TIMELINE_READ
  ASSIGNMENT_READ
  ASSIGNMENT_CREATE
  ASSIGNMENT_SUGGESTIONS
  ASSIGNMENT_RUN_AUTO
  SERVICE_REQUEST_READ
  SERVICE_REQUEST_CREATE
  SERVICE_REQUEST_CLAIM
  SERVICE_REQUEST_PATCH
  SERVICE_REQUEST_CANCEL
  LOST_FOUND_READ
  LOST_FOUND_CREATE
  LOST_FOUND_UPDATE
  INSPECTION_CREATE
  ROOM_TYPE_READ
  ROOM_TYPE_WRITE
  FLOOR_PLAN_READ
  FLOOR_PLAN_WRITE
  ANALYTICS_READ
  TEAM_CHAT_READ
  TEAM_CHAT_POST
  USERS_READ
  USERS_READ_HOUSEKEEPERS
  USERS_WRITE
  USERS_DELETE
  SETTINGS_READ
  SETTINGS_WRITE
  DAMAGE_REPORT_CREATE
  DAMAGE_REPORT_READ
  DAMAGE_REPORT_UPDATE
  SHIFT_READ
  SHIFT_MANAGE
}

enum ChecklistTaskStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum ServiceRequestPriority {
  NORMAL
  URGENT
}

enum ServiceRequestStatus {
  CREATED
  OPEN
  CLAIMED
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum LostFoundStatus {
  FOUND
  STORED
  CLAIMED
  CLOSED
}

enum RoomDamageType {
  FURNITURE
  FIXTURES
  WALL_OR_CEILING
  FLOOR
  WINDOW_OR_DOOR
  BATHROOM
  ELECTRICAL_OR_APPLIANCE
  OTHER
}

enum RoomDamageReportStatus {
  REPORTED
  ACKNOWLEDGED
  RESOLVED
}

enum AssignmentStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PhotoUploadStatus {
  PENDING
  READY
}

enum TeamChatReactionType {
  THUMBS_UP
  CHECK_MARK
  HEART
  EYES
  EXCLAMATION_QUESTION
}

model HotelSettings {
  id        String   @id @default(cuid())
  name      String   @default("Hotel")
  timezone  String   @default("UTC")
  settings  Json     @default("{}")
  updatedAt DateTime @updatedAt
}

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  passwordHash String
  name         String
  phone        String?
  isActive     Boolean         @default(true)
  role         UserRole
  titlePrefix  UserTitlePrefix @default(CLEANER)
  /// Object-storage key for the user's avatar photo. URLs are resolved on read via presigned GETs.
  avatarS3Key  String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  refreshTokens      RefreshToken[]
  cleaningSessions   CleaningSession[] @relation("AssignedSessions")
  roomChecklistTasks RoomChecklistTask[]
  roomPhotos         RoomPhoto[]
  serviceRequestsCreated ServiceRequest[] @relation("CreatedBy")
  serviceRequestsClaimed ServiceRequest[] @relation("ClaimedBy")
  lostFoundReported  LostFoundItem[]
  damageReportsReported RoomDamageReport[]
  shifts             Shift[]
  roomAssignmentsAsHousekeeper RoomAssignment[] @relation("HousekeeperAssignment")
  roomAssignmentsAsAssigner    RoomAssignment[] @relation("AssignerAssignment")
  inspections        RoomInspection[]
  // Admin can maintain custom floor-plan layouts.
  floorPlansUpdated  FloorPlan[]
  teamChatMessages         TeamChatMessage[]
  teamChatMessageReactions TeamChatMessageReaction[]
  permissionGrants         UserPermissionGrant[]
  roleAssignments          UserRoleAssignment[]
  favurMap                 FavurUserMap[]
}

/**
 * Admin-defined custom roles (Discord-style). A user can have any number of
 * these in addition to their built-in `UserRole` (account type). Effective
 * permissions are the union of: account-type defaults, individual grants,
 * and every assigned custom role's permission set.
 */
model Role {
  id          String               @id @default(cuid())
  name        String               @unique
  /// Hex color (with leading #) shown as a chip/dot in the UI.
  color       String               @default("#99aab5")
  /// Higher = sorted toward the top in role lists. Non-negative.
  position    Int                  @default(0)
  description String?
  /// Built-in role; protected from deletion through the API.
  isSystem    Boolean              @default(false)
  permissions RolePermission[]
  members     UserRoleAssignment[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([position])
}

model RolePermission {
  id         String         @id @default(cuid())
  roleId     String
  role       Role           @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission PermissionCode
  createdAt  DateTime       @default(now())

  @@unique([roleId, permission])
  @@index([roleId])
}

model UserRoleAssignment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model UserPermissionGrant {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission PermissionCode
  createdAt  DateTime       @default(now())

  @@unique([userId, permission])
  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model RoomType {
  id                         String              @id @default(cuid())
  name                       String
  code                       String              @unique
  defaultChecklistTemplateId String?
  defaultChecklistTemplate   ChecklistTemplate?  @relation(fields: [defaultChecklistTemplateId], references: [id])
  rooms                      Room[]
  checklistTemplates         ChecklistTemplate[] @relation("RoomTypeTemplates")
}

model ChecklistTemplate {
  id          String   @id @default(cuid())
  name        String
  version     Int      @default(1)
  roomTypeId  String?
  roomType    RoomType? @relation("RoomTypeTemplates", fields: [roomTypeId], references: [id], onDelete: SetNull)
  tasks       ChecklistTemplateTask[]
  states      RoomChecklistState[]
  roomTypesDefault RoomType[]
}

model ChecklistTemplateTask {
  id          String            @id @default(cuid())
  templateId  String
  template    ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sortOrder   Int
  label       String
  code        String
  required    Boolean           @default(true)
  roomTasks   RoomChecklistTask[]

  @@unique([templateId, code])
  @@index([templateId])
}

model Room {
  id          String   @id @default(cuid())
  roomNumber  String   @unique
  floor       Int?
  roomTypeId  String
  roomType    RoomType @relation(fields: [roomTypeId], references: [id])
  outOfOrder  Boolean  @default(false)
  oooReason   String?
  oooUntil    DateTime?
  notes       String?
  metadata    Json     @default("{}")
  /** Set when assigned housekeeper confirms clean (checklist + photo). Drives derived CLEAN vs IN_PROGRESS. */
  cleaningDeclaredAt DateTime?

  checklistStates  RoomChecklistState[]
  cleaningSessions CleaningSession[]
  photos           RoomPhoto[]
  serviceRequests  ServiceRequest[]
  lostFoundItems   LostFoundItem[]
  damageReports    RoomDamageReport[]
  assignments      RoomAssignment[]
  inspections      RoomInspection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoomChecklistState {
  id         String            @id @default(cuid())
  roomId     String
  room       Room              @relation(fields: [roomId], references: [id], onDelete: Cascade)
  templateId String
  template   ChecklistTemplate @relation(fields: [templateId], references: [id])
  updatedAt  DateTime          @updatedAt
  tasks      RoomChecklistTask[]

  @@unique([roomId])
}

model RoomChecklistTask {
  id                 String              @id @default(cuid())
  stateId            String
  state              RoomChecklistState  @relation(fields: [stateId], references: [id], onDelete: Cascade)
  templateTaskId     String
  templateTask       ChecklistTemplateTask @relation(fields: [templateTaskId], references: [id])
  status             ChecklistTaskStatus @default(NOT_STARTED)
  updatedByUserId    String?
  updatedBy          User?               @relation(fields: [updatedByUserId], references: [id])
  updatedAt          DateTime            @updatedAt
  supervisorOverride Boolean             @default(false)

  @@unique([stateId, templateTaskId])
}

model CleaningSession {
  id              String    @id @default(cuid())
  roomId          String
  room            Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  assignedUserId  String
  assignedUser    User      @relation("AssignedSessions", fields: [assignedUserId], references: [id])
  startedAt       DateTime  @default(now())
  completedAt     DateTime?

  photos RoomPhoto[]

  @@index([roomId])
  @@index([assignedUserId])
}

model RoomInspection {
  id              String   @id @default(cuid())
  roomId          String
  room            Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  inspectorUserId String
  inspector       User     @relation(fields: [inspectorUserId], references: [id])
  inspectedAt     DateTime @default(now())
  notes           String?
  passed          Boolean  @default(true)

  @@index([roomId])
}

model RoomPhoto {
  id                 String            @id @default(cuid())
  roomId             String
  room               Room              @relation(fields: [roomId], references: [id], onDelete: Cascade)
  uploadedByUserId   String
  uploadedBy         User              @relation(fields: [uploadedByUserId], references: [id])
  s3Key              String
  mime               String?
  bytes              Int?
  takenAt            DateTime?
  status             PhotoUploadStatus @default(PENDING)
  cleaningSessionId  String?
  cleaningSession    CleaningSession?  @relation(fields: [cleaningSessionId], references: [id])
  createdAt          DateTime          @default(now())

  @@index([roomId])
}

model ServiceRequestType {
  id                         String   @id @default(cuid())
  code                       String   @unique
  label                      String
  mapsToChecklistTaskCode    String?

  requests ServiceRequest[]
}

model ServiceRequest {
  id                String                 @id @default(cuid())
  roomId            String
  room              Room                   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  typeId            String
  type              ServiceRequestType     @relation(fields: [typeId], references: [id])
  priority          ServiceRequestPriority @default(NORMAL)
  description       String?
  status            ServiceRequestStatus   @default(CREATED)
  createdByUserId   String
  createdBy         User                   @relation("CreatedBy", fields: [createdByUserId], references: [id])
  claimedByUserId   String?
  claimedBy         User?                  @relation("ClaimedBy", fields: [claimedByUserId], references: [id])
  claimedAt         DateTime?
  resolvedAt        DateTime?
  version           Int                    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([roomId])
}

model LostFoundItem {
  id                 String         @id @default(cuid())
  roomId             String?
  room               Room?          @relation(fields: [roomId], references: [id], onDelete: SetNull)
  reportedByUserId   String
  reportedBy         User           @relation(fields: [reportedByUserId], references: [id])
  description        String
  photoS3Key         String?
  status             LostFoundStatus @default(FOUND)
  /// Set when a housekeeper reports the item. Null when reception backfills an existing storage item.
  foundAt            DateTime?
  storedAt           DateTime?
  storedLocation     String?
  guestContactedAt   DateTime?
  claimedByGuestInfo Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model RoomDamageReport {
  id                 String                 @id @default(cuid())
  roomId             String
  room               Room                   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  reportedByUserId   String
  reportedBy         User                   @relation(fields: [reportedByUserId], references: [id])
  damageType         RoomDamageType
  description        String
  photoS3Key         String
  status             RoomDamageReportStatus @default(REPORTED)
  reportedAt         DateTime               @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([roomId])
}

model Shift {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startsAt  DateTime
  endsAt    DateTime
  /// Where the row originated. "manual" for hand entries, "favur" for sync.
  source    String   @default("manual")
  /// External id from the source system (e.g. Favur shift id). Lets us upsert.
  sourceId  String?
  /// Free-form label (Favur shift code, location, role, etc.).
  label     String?
  /// Hex color for the chip on the roster (defaults to user's role color).
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([source, sourceId])
  @@index([userId, startsAt, endsAt])
  @@index([startsAt, endsAt])
}

/// Singleton-ish config for the Favur shift import. There should normally be
/// exactly one row (id = "default"). Credentials are encrypted at rest.
model FavurIntegration {
  id                 String    @id @default("default")
  enabled            Boolean   @default(false)
  baseUrl            String    @default("https://web.favur.ch")
  email              String?
  encryptedPassword  String?
  /// Last successful auth token + cookies (encrypted JSON blob).
  encryptedSession   String?
  sessionExpiresAt   DateTime?
  /// Sync window in days, looking forward from "today".
  windowDays         Int       @default(14)
  lastSyncAt         DateTime?
  lastSyncStatus     String?
  lastSyncError      String?
  lastSyncCount      Int       @default(0)
  /// True while a sync is currently running (advisory lock).
  syncInProgress     Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

/// Mapping from Favur employee identifier to a local User. Rows are created
/// the first time we see a Favur user; admins map them to local accounts.
model FavurUserMap {
  id               String    @id @default(cuid())
  favurUserId      String    @unique
  favurDisplayName String?
  userId           String?
  user             User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  lastSeenAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId])
}

model RoomAssignment {
  id                  String           @id @default(cuid())
  roomId              String
  room                Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  housekeeperUserId   String
  housekeeper         User             @relation("HousekeeperAssignment", fields: [housekeeperUserId], references: [id])
  assignedByUserId    String?
  assigner            User?            @relation("AssignerAssignment", fields: [assignedByUserId], references: [id])
  assignedAt          DateTime         @default(now())
  status              AssignmentStatus @default(PENDING)

  @@index([roomId])
  @@index([housekeeperUserId])
}

model AnalyticsDaily {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  metricKey String
  value     Float
  meta      Json     @default("{}")

  @@unique([date, metricKey])
}

model FloorPlan {
  id              String   @id @default(cuid())
  floor           Int      @unique
  layout          Json     @default("[]")
  updatedByUserId String?
  updatedBy       User?    @relation(fields: [updatedByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TeamChatMessage {
  id        String   @id @default(cuid())
  body      String   @db.VarChar(2000)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replyToId String?
  replyTo   TeamChatMessage? @relation("TeamChatReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   TeamChatMessage[] @relation("TeamChatReplies")
  reactions TeamChatMessageReaction[]
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([replyToId])
}

model TeamChatMessageReaction {
  id        String               @id @default(cuid())
  messageId String
  message   TeamChatMessage      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      TeamChatReactionType
  createdAt DateTime             @default(now())

  @@unique([messageId, userId, type])
  @@index([messageId])
}
